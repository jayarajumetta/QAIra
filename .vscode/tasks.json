{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "postgres:up",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "backend/docker-compose.yml",
        "up",
        "-d",
        "postgres"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "qaira-debug"
      }
    },
    {
      "label": "frontend:dev",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+http://"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "qaira-debug"
      }
    }
  ]
}
